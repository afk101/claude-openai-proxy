# ========================================
# Claude OpenAI Proxy 环境变量配置示例
# ========================================
# 复制此文件为 .env 并根据实际情况修改

# ========================================
# 必选配置
# ========================================

# Required: Claude 上游 API 密钥
# 优先级：CLAUDE_API_KEY > ANTHROPIC_API_KEY（二选一即可）
# 推荐使用 CLAUDE_API_KEY
CLAUDE_API_KEY="你的上游密钥"

# Required: 支持 Claude Response 协议的 Base URL
# 默认: https://api.anthropic.com
# 如果你的上游是其他提供商（如代理服务、自托管等），请修改此项
CLAUDE_BASE_URL="支持claude response协议的baseurl"

# ========================================
# 可选配置
# ========================================

# Optional: Anthropic API 版本（默认: 2023-06-01）
# ANTHROPIC_VERSION="2023-06-01"

# Optional: 代理访问密钥
# 设置后，客户端请求时需要在请求头中提供此 API Key
# 留空则表示不需要验证
# PROXY_API_KEY="your-proxy-api-key"

# Optional: 服务监听地址（默认: 0.0.0.0）
# HOST="0.0.0.0"

# Optional: 服务监听端口（默认: 8000）
# PORT="8000"

# Optional: 日志级别（默认: INFO）
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL="INFO"

# Optional: 请求超时配置（单位: 秒）
# REQUEST_TIMEOUT="90"
# Optional: 流式读取超时（单位: 秒，默认: 480）
# READ_TIMEOUT="480"
